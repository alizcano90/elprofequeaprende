DirectoryIndex index.php index.html
Options -Indexes

<IfModule mod_rewrite.c>
  RewriteEngine On

  RewriteCond %{THE_REQUEST} \s/+index\.php[\s?] [NC]
  RewriteRule ^index\.php$ /?pg=home [R=301,L]

  RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
  RewriteRule ^index\.html$ /?pg=home [R=301,L]
</IfModule>

<FilesMatch "^(\.env|config\.local\.php|local\.php|composer\.(json|lock)|.*\.bak|.*\.backup|.*\.log)$">
  Require all denied
</FilesMatch>

<FilesMatch "\.(css|js|png|jpg|jpeg|gif|webp|svg|ico|woff|woff2|ttf|zip|pdf|xlsx)$">
  Require all granted
</FilesMatch>
